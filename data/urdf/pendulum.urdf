<?xml version="1.0"?>
<robot name="pendulum">
  <link name="world"/>

  <link name="link1">
    <inertial>
      <origin xyz="0 0 -0.5" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.083333" ixy="0.0" ixz="0.0" iyy="0.083333" iyz="0.0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.5" rpy="0 0 0"/>
      <geometry>
        <capsule radius="0.04" length="1.0"/>
      </geometry>
      <material name="steel">
        <color rgba="0.25 0.45 0.85 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.5" rpy="0 0 0"/>
      <geometry>
        <capsule radius="0.04" length="1.0"/>
      </geometry>
    </collision>
  </link>

  <joint name="hinge" type="revolute">
    <parent link="world"/>
    <child link="link1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.28318530718" upper="6.28318530718" effort="200.0" velocity="100.0"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>
</robot>
