<?xml version="1.0"?>
<robot name="cartpole_minimal">
  <link name="world"/>

  <link name="cart">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.010" ixy="0" ixz="0" iyy="0.010" iyz="0" izz="0.010"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.4 0.2 0.2"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.4 0.2 0.2"/></geometry>
    </collision>
  </link>

  <link name="pole">
    <inertial>
      <origin xyz="0 0 -0.5" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.020" ixy="0" ixz="0" iyy="0.020" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 -0.5" rpy="0 0 0"/>
      <geometry><box size="0.1 0.1 1.0"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.5" rpy="0 0 0"/>
      <geometry><box size="0.1 0.1 1.0"/></geometry>
    </collision>
  </link>

  <joint name="world_to_cart" type="prismatic">
    <parent link="world"/>
    <child link="cart"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-2.0" upper="2.0" effort="1000" velocity="10"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <joint name="cart_to_pole" type="revolute">
    <parent link="cart"/>
    <child link="pole"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="1000" velocity="10"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>
</robot>
